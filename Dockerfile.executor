FROM golang:1.25-alpine AS builder
WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/execution-agent ./cmd/execution-agent

FROM alpine:3.21
WORKDIR /app

RUN apk add --no-cache ca-certificates tzdata

COPY --from=builder /out/execution-agent /app/execution-agent
COPY gitops-skills /app/gitops-skills

ENTRYPOINT ["/app/execution-agent"]
CMD ["-mode", "probe", "-skills-root", "/app/gitops-skills"]
