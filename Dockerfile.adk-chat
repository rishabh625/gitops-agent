FROM golang:1.25-alpine AS builder
WORKDIR /src


COPY go.mod go.sum ./
COPY vendor ./vendor
ENV GOFLAGS=-mod=vendor


COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/adk-chat ./cmd/adk-chat

FROM alpine:3.21
WORKDIR /app

RUN apk add --no-cache ca-certificates tzdata wget

COPY --from=builder /out/adk-chat /app/adk-chat
COPY scripts/cloud-run-entrypoint.sh /app/cloud-run-entrypoint.sh
RUN chmod +x /app/cloud-run-entrypoint.sh
COPY gitops-skills /app/gitops-skills

ENTRYPOINT ["/app/adk-chat"]
CMD ["console"]
