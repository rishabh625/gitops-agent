FROM golang:1.25-alpine AS builder
WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/adk-chat ./cmd/adk-chat

FROM alpine:3.21
WORKDIR /app

RUN apk add --no-cache ca-certificates tzdata wget

COPY --from=builder /out/adk-chat /app/adk-chat
COPY gitops-skills /app/gitops-skills

ENTRYPOINT ["/app/adk-chat"]
CMD ["console"]
