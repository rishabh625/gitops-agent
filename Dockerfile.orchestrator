FROM golang:1.25-alpine AS builder
WORKDIR /src


COPY go.mod go.sum ./
COPY vendor ./vendor
ENV GOFLAGS=-mod=vendor


COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/orchestrator-agent ./cmd/orchestrator-agent

FROM alpine:3.21
WORKDIR /app

RUN apk add --no-cache ca-certificates tzdata

COPY --from=builder /out/orchestrator-agent /app/orchestrator-agent
COPY gitops-skills /app/gitops-skills

ENTRYPOINT ["/app/orchestrator-agent"]
CMD ["-mode", "probe", "-skills-root", "/app/gitops-skills"]
